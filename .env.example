# OKX API credentials. Copy this file to .env and fill in your own values.
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# Use 1 for OKX demo trading, 0 for production trading.
OKX_SIMULATED_TRADING=1

# Optional. Keep the default unless OKX asks you to use another domain.
OKX_BASE_URL=https://www.okx.com

# Optional. Use this only if the server reaches OKX through an HTTP proxy.
OKX_PROXY=

# Optional. Avoids Cloudflare rejecting Python's default request signature.
OKX_USER_AGENT=curl/8.10.1

# Safety switch. Keep 0 unless you intentionally want the dashboard to send live orders.
OKX_ENABLE_LIVE_TRADING=0
